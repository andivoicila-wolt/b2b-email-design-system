<!-- ============================================
     MODULE: Two-Column Grid
     Supports: Image + text side by side, stacks on mobile
     ============================================ -->

<!-- Variant A: Image Left, Text Right -->
<mj-section background-color="#021738" padding="36px 30px" direction="ltr" border-radius="12px 12px 0 0">
  <mj-column width="48%" padding="0 10px 0 0">
    <mj-image src="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=600&h=400&fit=crop" alt="Feature image" border-radius="10px" padding="0" fluid-on-mobile="true" />
  </mj-column>
  <mj-column width="52%" vertical-align="middle" padding="0 0 0 10px">
    <mj-text font-family="'omnes-pro', 'Avenir Next', 'Segoe UI', 'Helvetica Neue', Helvetica, Arial, sans-serif" font-size="20px" font-weight="700" color="#ffffff" line-height="26px" padding="0 0 12px 0">
      Reach more customers with Wolt Ads
    </mj-text>
    <mj-text font-family="'omnes-pro', 'Avenir Next', 'Segoe UI', 'Helvetica Neue', Helvetica, Arial, sans-serif" font-size="15px" font-weight="400" color="rgba(255,255,255,0.78)" line-height="24px" padding="0 0 20px 0">
      Boost your visibility and drive more orders with targeted campaigns directly on the Wolt app.
    </mj-text>
    <mj-button background-color="#00c2e8" color="#021738" font-family="'omnes-pro', 'Avenir Next', 'Segoe UI', 'Helvetica Neue', Helvetica, Arial, sans-serif" font-size="14px" font-weight="600" border-radius="8px" inner-padding="12px 24px" padding="0" align="left" href="#">
      Get started
    </mj-button>
  </mj-column>
</mj-section>

<!-- Spacer / Divider -->
<mj-section background-color="#021738" padding="0 40px">
  <mj-column><mj-divider border-color="rgba(255,255,255,0.1)" border-width="1px" padding="0" /></mj-column>
</mj-section>

<!-- Variant B: Text Left, Image Right -->
<mj-section background-color="#021738" padding="36px 30px" direction="ltr" border-radius="0 0 12px 12px">
  <mj-column width="52%" vertical-align="middle" padding="0 10px 0 0">
    <mj-text font-family="'omnes-pro', 'Avenir Next', 'Segoe UI', 'Helvetica Neue', Helvetica, Arial, sans-serif" font-size="20px" font-weight="700" color="#ffffff" line-height="26px" padding="0 0 12px 0">
      Analytics that help you grow
    </mj-text>
    <mj-text font-family="'omnes-pro', 'Avenir Next', 'Segoe UI', 'Helvetica Neue', Helvetica, Arial, sans-serif" font-size="15px" font-weight="400" color="rgba(255,255,255,0.78)" line-height="24px" padding="0 0 20px 0">
      Track your sales, busiest hours, and top-performing items — all from the Merchant Portal.
    </mj-text>
    <mj-button background-color="#00c2e8" color="#021738" font-family="'omnes-pro', 'Avenir Next', 'Segoe UI', 'Helvetica Neue', Helvetica, Arial, sans-serif" font-size="14px" font-weight="600" border-radius="8px" inner-padding="12px 24px" padding="0" align="left" href="#">
      View analytics
    </mj-button>
  </mj-column>
  <mj-column width="48%" padding="0 0 0 10px">
    <mj-image src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=600&h=400&fit=crop" alt="Analytics feature" border-radius="10px" padding="0" fluid-on-mobile="true" />
  </mj-column>
</mj-section>
